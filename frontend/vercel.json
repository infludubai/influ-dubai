{
  "framework": "nextjs",
  "regions": ["dxb1"],
  "env": {
    "NEXT_PUBLIC_API_URL": "@infludubai_api_url",
    "NEXT_PUBLIC_WS_URL": "@infludubai_ws_url",
    "NEXT_PUBLIC_SUPABASE_URL": "@infludubai_supabase_url"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
