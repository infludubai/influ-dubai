# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/infludubai?sslmode=require

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-long-random-string-min-32-chars
JWT_REFRESH_SECRET=change-me-different-long-random-string

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://yourdomain.com

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4001
NODE_ENV=production

# ── Stripe (optional — omit for mock mode) ────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── OpenAI (optional — omit for rule-based fraud detection only) ──────────────
OPENAI_API_KEY=sk-...

# ── Email (optional — omit to log links to console) ──────────────────────────
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-smtp-password
MAIL_FROM=InfluDubai <noreply@yourdomain.com>
