# ── Database ──────────────────────────────────────────────────────────────────
# Render Postgres: copy the "Internal Database URL" from your Render Postgres instance
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/infludubai?sslmode=require

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-long-random-string-min-32-chars
JWT_REFRESH_SECRET=change-me-different-long-random-string

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your Vercel frontend URL — no trailing slash
ALLOWED_ORIGINS=https://influ-dubai.vercel.app

# ── Server ────────────────────────────────────────────────────────────────────
PORT=10000
NODE_ENV=production

# ── Supabase Storage ──────────────────────────────────────────────────────────
# From: supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Use the "service_role" key (secret — never expose in frontend)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe (optional — billing is mocked without these) ───────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── OpenAI (optional — AI features degrade gracefully without this) ───────────
OPENAI_API_KEY=sk-...

# ── Email (optional — links are logged to console when omitted) ───────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=your-resend-api-key
MAIL_FROM=InfluDubai <noreply@infludubai.com>
