# Copy to .env and fill in your values before running docker-compose

# Database password (shared by db + backend services)
DB_PASSWORD=change-me-strong-password

# Auth secrets — generate with: openssl rand -hex 32
JWT_SECRET=change-me-32-char-min-random-string
JWT_REFRESH_SECRET=change-me-different-32-char-string

# Frontend origin that the backend will accept CORS from
ALLOWED_ORIGINS=http://localhost:3002

# Optional: point frontend to the public-facing API URL
NEXT_PUBLIC_API_URL=http://localhost:4001/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:4001

# Node environment (development | production)
NODE_ENV=development

# Optional third-party services (leave blank for mock/console modes)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
OPENAI_API_KEY=
