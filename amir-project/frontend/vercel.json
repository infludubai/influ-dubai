{
  "rewrites": [
    { "source": "/ads.txt",    "destination": "https://amir-node-api.onrender.com/ads.txt" },
    { "source": "/sitemap.xml","destination": "https://amir-node-api.onrender.com/sitemap.xml" },
    { "source": "/(.*)",       "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
