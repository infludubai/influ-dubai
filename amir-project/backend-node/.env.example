NODE_ENV=production
PORT=8080
API_PREFIX=/api

# Database (Railway MySQL — copy values from Railway service variables)
DB_HOST=mysql.railway.internal
DB_PORT=3306
DB_DATABASE=railway
DB_USERNAME=root
DB_PASSWORD=

# Storage path (Railway persistent volume or /tmp for ephemeral)
STORAGE_PATH=/app/storage

# App URLs
APP_URL=https://a-mir.com
PUBLIC_API_URL=https://api.a-mir.com/api

# Email (from DB admin settings, or set here as fallback)
MAIL_HOST=
MAIL_PORT=465
MAIL_ENCRYPTION=ssl
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=info@a-mir.com
MAIL_FROM_NAME=Amir Nazir

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.a-mir.com/api/auth/google/callback

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WEBHOOK_TOKEN=

# OpenAI (optional, for AI chat)
OPENAI_API_KEY=
